<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════ -->
    <!-- SHART DARK THEME — Premium Color Palette           -->
    <!-- ═══════════════════════════════════════════════════ -->
    
    <!-- Background Layers (darkest → lightest) -->
    <Color x:Key="BgDeep">#FF0A0A0F</Color>
    <Color x:Key="BgBase">#FF12121A</Color>
    <Color x:Key="BgSurface">#FF1A1A26</Color>
    <Color x:Key="BgElevated">#FF222233</Color>
    <Color x:Key="BgHover">#FF2A2A3D</Color>
    
    <!-- Accent: Electric Cyan-Blue Gradient -->
    <Color x:Key="AccentPrimary">#FF00D4FF</Color>
    <Color x:Key="AccentSecondary">#FF7B61FF</Color>
    <Color x:Key="AccentTertiary">#FFFF6B9D</Color>
    
    <!-- Status Colors -->
    <Color x:Key="StatusSuccess">#FF00E676</Color>
    <Color x:Key="StatusWarning">#FFFFAB40</Color>
    <Color x:Key="StatusError">#FFFF5252</Color>
    <Color x:Key="StatusInfo">#FF40C4FF</Color>
    
    <!-- Text -->
    <Color x:Key="TextPrimary">#FFFAFAFA</Color>
    <Color x:Key="TextSecondary">#FFB0B0C0</Color>
    <Color x:Key="TextMuted">#FF6B6B80</Color>
    
    <!-- Borders -->
    <Color x:Key="BorderDefault">#FF2A2A3D</Color>
    <Color x:Key="BorderAccent">#FF00D4FF</Color>
    
    <!-- Solid Brushes -->
    <SolidColorBrush x:Key="BgDeepBrush" Color="{StaticResource BgDeep}"/>
    <SolidColorBrush x:Key="BgBaseBrush" Color="{StaticResource BgBase}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}"/>
    <SolidColorBrush x:Key="BgElevatedBrush" Color="{StaticResource BgElevated}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
    
    <SolidColorBrush x:Key="AccentPrimaryBrush" Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="AccentSecondaryBrush" Color="{StaticResource AccentSecondary}"/>
    <SolidColorBrush x:Key="AccentTertiaryBrush" Color="{StaticResource AccentTertiary}"/>
    
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="{StaticResource StatusSuccess}"/>
    <SolidColorBrush x:Key="StatusWarningBrush" Color="{StaticResource StatusWarning}"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="{StaticResource StatusError}"/>
    <SolidColorBrush x:Key="StatusInfoBrush" Color="{StaticResource StatusInfo}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    
    <SolidColorBrush x:Key="BorderDefaultBrush" Color="{StaticResource BorderDefault}"/>
    <SolidColorBrush x:Key="BorderAccentBrush" Color="{StaticResource BorderAccent}"/>
    
    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentSecondary}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="HeroGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentSecondary}" Offset="0.5"/>
        <GradientStop Color="{StaticResource AccentTertiary}" Offset="1"/>
    </LinearGradientBrush>
    
    <LinearGradientBrush x:Key="ProgressGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="{StaticResource AccentPrimary}" Offset="0"/>
        <GradientStop Color="{StaticResource AccentSecondary}" Offset="1"/>
    </LinearGradientBrush>
    
    <!-- Glassmorphism Background -->
    <SolidColorBrush x:Key="GlassBrush" Color="#2A1A1A26"/>
    
</ResourceDictionary>
