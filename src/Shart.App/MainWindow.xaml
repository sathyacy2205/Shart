<Window x:Class="Shart.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Shart.App"
        xmlns:views="clr-namespace:Shart.App.Views"
        Title="Shart — High-Speed File Transfer"
        Height="750" Width="1150" MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeepBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResize">

    <Window.Resources>
        <!-- Slide-in animation for content switching -->
        <Storyboard x:Key="ContentFadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                           From="0" To="1" Duration="0:0:0.2"/>
            <ThicknessAnimation Storyboard.TargetProperty="Margin"
                               From="20,0,0,0" To="0" Duration="0:0:0.2">
                <ThicknessAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut"/>
                </ThicknessAnimation.EasingFunction>
            </ThicknessAnimation>
        </Storyboard>
    </Window.Resources>

    <Border CornerRadius="12" Background="{StaticResource BgDeepBrush}"
            BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>   <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
            </Grid.RowDefinitions>

            <!-- ═══════════ CUSTOM TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="{StaticResource BgBaseBrush}"
                    CornerRadius="12,12,0,0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center">
                        <!-- App Icon -->
                        <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="SHART" FontFamily="{StaticResource PrimaryFont}"
                                   FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}"
                                   VerticalAlignment="Center" LetterSpacing="2"/>
                        <TextBlock Text="     v1.0.0" Style="{StaticResource Caption}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Window Controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                        <Button Content="─" Click="Minimize_Click" Style="{StaticResource GhostButton}"
                                Padding="12,4" FontSize="11" Margin="2"/>
                        <Button Content="□" Click="Maximize_Click" Style="{StaticResource GhostButton}"
                                Padding="12,4" FontSize="11" Margin="2"/>
                        <Button x:Name="CloseBtn" Content="✕" Click="Close_Click"
                                Padding="12,4" FontSize="11" Margin="2"
                                Background="Transparent" Foreground="{StaticResource TextSecondaryBrush}"
                                BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════ MAIN LAYOUT ═══════════ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240"/>  <!-- Sidebar -->
                    <ColumnDefinition Width="*"/>    <!-- Content -->
                </Grid.ColumnDefinitions>

                <!-- ═══════════ SIDEBAR ═══════════ -->
                <Border Grid.Column="0" Background="{StaticResource BgBaseBrush}"
                        BorderBrush="{StaticResource BorderDefaultBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>  <!-- Connection Status -->
                            <RowDefinition Height="*"/>     <!-- Navigation -->
                            <RowDefinition Height="Auto"/>  <!-- Speed Display -->
                        </Grid.RowDefinitions>

                        <!-- Connection Status Card -->
                        <Border Grid.Row="0" Margin="12,16,12,8" Style="{StaticResource Card}" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="8" Height="8" Margin="0,0,8,0"
                                             Fill="{StaticResource StatusSuccessBrush}"/>
                                    <TextBlock x:Name="ConnectionStatus" Text="Ready"
                                               Style="{StaticResource Body}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <TextBlock x:Name="DeviceNameText" Text="No device connected"
                                           Style="{StaticResource Caption}" Margin="16,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="1" Margin="12,8">
                            <TextBlock Text="MENU" Style="{StaticResource Caption}"
                                       Margin="16,8,0,12" FontWeight="SemiBold" LetterSpacing="1.5"/>
                            
                            <RadioButton x:Name="NavTransfers" Style="{StaticResource NavButton}"
                                         Content="📊  Transfers" IsChecked="True"
                                         Checked="NavTransfers_Checked"/>
                            <RadioButton x:Name="NavRadar" Style="{StaticResource NavButton}"
                                         Content="📡  Device Radar"
                                         Checked="NavRadar_Checked"/>
                            <RadioButton x:Name="NavDropZone" Style="{StaticResource NavButton}"
                                         Content="📁  Drop Zone"
                                         Checked="NavDropZone_Checked"/>
                            <RadioButton x:Name="NavQrCode" Style="{StaticResource NavButton}"
                                         Content="🔗  QR Pairing"
                                         Checked="NavQrCode_Checked"/>

                            <Separator Margin="16,16" Background="{StaticResource BorderDefaultBrush}"/>
                            
                            <RadioButton Style="{StaticResource NavButton}"
                                         Content="📜  History"
                                         Checked="NavHistory_Checked"/>
                            <RadioButton Style="{StaticResource NavButton}"
                                         Content="⚙️  Settings"
                                         Checked="NavSettings_Checked"/>
                        </StackPanel>

                        <!-- Speed Display -->
                        <Border Grid.Row="2" Margin="12,8,12,16" Style="{StaticResource Card}" Padding="16">
                            <StackPanel>
                                <TextBlock Text="CURRENT SPEED" Style="{StaticResource Caption}"
                                           FontWeight="SemiBold" LetterSpacing="1"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="SpeedDisplay" Text="0"
                                               Style="{StaticResource MetricLarge}"/>
                                    <TextBlock x:Name="SpeedUnit" Text="MB/s"
                                               Style="{StaticResource MetricUnit}"/>
                                </StackPanel>
                                <ProgressBar x:Name="SpeedBar" Value="0" Maximum="100"
                                             Style="{StaticResource AccentProgressBar}"
                                             Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- ═══════════ CONTENT AREA ═══════════ -->
                <Grid Grid.Column="1" Margin="24,16">
                    <!-- Transfer Queue View (Default) -->
                    <Grid x:Name="TransferView" Visibility="Visible">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,20">
                            <TextBlock Text="Transfer Dashboard" Style="{StaticResource H2}"/>
                            <TextBlock Text="Active, queued, and completed file transfers"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,0"/>
                        </StackPanel>

                        <!-- Stats Row -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Width="160">
                                    <StackPanel>
                                        <TextBlock Text="Active" Style="{StaticResource Caption}"/>
                                        <TextBlock Text="2" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentPrimaryBrush}"
                                                   FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Width="160">
                                    <StackPanel>
                                        <TextBlock Text="Completed" Style="{StaticResource Caption}"/>
                                        <TextBlock Text="0" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource StatusSuccessBrush}"
                                                   FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource Card}" Margin="0,0,12,0" Width="160">
                                    <StackPanel>
                                        <TextBlock Text="Total Transferred" Style="{StaticResource Caption}"/>
                                        <TextBlock Text="1.12 GB" FontSize="28" FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontFamily="{StaticResource MonoFont}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Transfer List -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TransferList">
                                    <!-- Demo Transfer Item 1 -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- File Icon -->
                                            <Border Grid.Column="0" Grid.RowSpan="3" 
                                                    Width="44" Height="44" CornerRadius="10"
                                                    Background="{StaticResource BgElevatedBrush}"
                                                    Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="🎬" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- File Info -->
                                            <TextBlock Grid.Column="1" Grid.Row="0"
                                                       Text="vacation_video.mp4" Style="{StaticResource Body}"
                                                       FontWeight="SemiBold"/>
                                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal"
                                                        Margin="0,2,0,0">
                                                <TextBlock Text="⬇ Incoming" Style="{StaticResource Caption}"/>
                                                <TextBlock Text="  •  " Style="{StaticResource Caption}"/>
                                                <TextBlock Text="2.33 GB" Style="{StaticResource Caption}"/>
                                                <TextBlock Text="  •  " Style="{StaticResource Caption}"/>
                                                <TextBlock Text="from Pixel 8 Pro" Style="{StaticResource Caption}"/>
                                            </StackPanel>

                                            <!-- Progress Bar -->
                                            <Grid Grid.Column="1" Grid.Row="2" Margin="0,8,0,0">
                                                <ProgressBar Value="48" Maximum="100"
                                                             Style="{StaticResource AccentProgressBar}"/>
                                            </Grid>

                                            <!-- Speed & Controls -->
                                            <StackPanel Grid.Column="2" Grid.RowSpan="3"
                                                        VerticalAlignment="Center" HorizontalAlignment="Right"
                                                        Margin="20,0,0,0">
                                                <TextBlock Text="119.2 MB/s" FontFamily="{StaticResource MonoFont}"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{StaticResource AccentPrimaryBrush}"
                                                           HorizontalAlignment="Right"/>
                                                <TextBlock Text="48% — 11s left" Style="{StaticResource Caption}"
                                                           HorizontalAlignment="Right" Margin="0,2,0,8"/>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                    <Button Content="⏸" Style="{StaticResource GhostButton}"
                                                            Padding="8,4" FontSize="12" Margin="0,0,4,0"/>
                                                    <Button Content="✕" Style="{StaticResource GhostButton}"
                                                            Padding="8,4" FontSize="12"
                                                            Foreground="{StaticResource StatusErrorBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Demo Transfer Item 2 (Pending) -->
                                    <Border Style="{StaticResource Card}" Margin="0,0,0,8" Opacity="0.7">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="10"
                                                    Background="{StaticResource BgElevatedBrush}"
                                                    Margin="0,0,16,0" VerticalAlignment="Center">
                                                <TextBlock Text="📦" FontSize="20"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="photos_backup.zip" Style="{StaticResource Body}"
                                                           FontWeight="SemiBold"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                                    <TextBlock Text="⬆ Outgoing" Style="{StaticResource Caption}"/>
                                                    <TextBlock Text="  •  " Style="{StaticResource Caption}"/>
                                                    <TextBlock Text="762.94 MB" Style="{StaticResource Caption}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <Border Grid.Column="2" CornerRadius="6" Padding="12,6"
                                                    Background="{StaticResource BgElevatedBrush}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="QUEUED" Style="{StaticResource Caption}"
                                                           Foreground="{StaticResource StatusWarningBrush}"
                                                           FontWeight="SemiBold"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Grid>

                    <!-- Radar View -->
                    <Grid x:Name="RadarViewPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Device Radar" Style="{StaticResource H2}"/>
                            <TextBlock Text="Scan for nearby devices over Wi-Fi Direct"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,24"/>

                            <!-- Radar Animation -->
                            <Border Width="300" Height="300" CornerRadius="150"
                                    Background="{StaticResource BgSurfaceBrush}"
                                    BorderBrush="{StaticResource BorderDefaultBrush}"
                                    BorderThickness="1" HorizontalAlignment="Center"
                                    Margin="0,0,0,24">
                                <Grid>
                                    <!-- Concentric rings -->
                                    <Ellipse Width="200" Height="200" Stroke="{StaticResource BorderDefaultBrush}"
                                             StrokeThickness="0.5" HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                    <Ellipse Width="100" Height="100" Stroke="{StaticResource BorderDefaultBrush}"
                                             StrokeThickness="0.5" HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                    <!-- Center dot (this device) -->
                                    <Ellipse Width="12" Height="12" Fill="{StaticResource AccentPrimaryBrush}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource AccentPrimary}"
                                                              ShadowDepth="0" BlurRadius="15" Opacity="0.8"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <!-- Demo device dots -->
                                    <Ellipse Width="10" Height="10" Fill="{StaticResource StatusSuccessBrush}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Margin="60,-80,0,0">
                                        <Ellipse.Effect>
                                            <DropShadowEffect Color="{StaticResource StatusSuccess}"
                                                              ShadowDepth="0" BlurRadius="10" Opacity="0.6"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentSecondaryBrush}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"
                                             Margin="-90,40,0,0"/>
                                </Grid>
                            </Border>

                            <Button Content="🔍  Start Scanning" Style="{StaticResource AccentButton}"
                                    HorizontalAlignment="Center"/>

                            <!-- Device List -->
                            <StackPanel Margin="0,24,0,0">
                                <Border Style="{StaticResource Card}" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Width="40" Height="40" CornerRadius="20"
                                                Background="{StaticResource BgElevatedBrush}" Margin="0,0,12,0">
                                            <TextBlock Text="📱" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Pixel 8 Pro" Style="{StaticResource Body}"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="192.168.49.2 • Strong signal"
                                                       Style="{StaticResource Caption}"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Connect"
                                                Style="{StaticResource AccentButton}"
                                                Padding="16,8" FontSize="12"
                                                VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <!-- Drop Zone View -->
                    <Grid x:Name="DropZoneViewPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Drop Zone" Style="{StaticResource H2}"/>
                            <TextBlock Text="Drag and drop files from Explorer to send"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,24"/>

                            <!-- Drop Area -->
                            <Border x:Name="DropArea" AllowDrop="True"
                                    MinHeight="300" CornerRadius="16"
                                    BorderThickness="2" Margin="0,0,0,16"
                                    Background="{StaticResource BgSurfaceBrush}"
                                    Drop="DropArea_Drop" DragOver="DropArea_DragOver"
                                    DragLeave="DropArea_DragLeave">
                                <Border.BorderBrush>
                                    <DrawingBrush Viewport="0,0,16,16" ViewportUnits="Absolute" TileMode="Tile">
                                        <DrawingBrush.Drawing>
                                            <GeometryDrawing>
                                                <GeometryDrawing.Pen>
                                                    <Pen Brush="{StaticResource BorderDefaultBrush}" Thickness="2"
                                                         DashStyle="{x:Static DashStyles.Dash}"/>
                                                </GeometryDrawing.Pen>
                                                <GeometryDrawing.Geometry>
                                                    <RectangleGeometry Rect="0,0,16,16"/>
                                                </GeometryDrawing.Geometry>
                                            </GeometryDrawing>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.BorderBrush>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Drop files here" Style="{StaticResource H3}"
                                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                    <TextBlock Text="or click to browse"
                                               Style="{StaticResource BodySecondary}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>

                            <Button Content="📁  Browse Files" Style="{StaticResource GhostButton}"
                                    HorizontalAlignment="Center" Click="BrowseFiles_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- QR Code View -->
                    <Grid x:Name="QrCodeViewPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="QR Pairing" Style="{StaticResource H2}"/>
                            <TextBlock Text="Scan this QR code from your Android device to connect"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,24"/>

                            <Border Style="{StaticResource GlassCard}" HorizontalAlignment="Center"
                                    Width="380">
                                <StackPanel HorizontalAlignment="Center">
                                    <!-- QR Code Placeholder -->
                                    <Border Width="220" Height="220" CornerRadius="12"
                                            Background="White" Margin="0,0,0,16"
                                            HorizontalAlignment="Center">
                                        <Grid>
                                            <TextBlock Text="QR" FontSize="48" FontWeight="Bold"
                                                       Foreground="#333"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>

                                    <!-- Connection Info -->
                                    <StackPanel Margin="0,8,0,0">
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Device:" Style="{StaticResource Caption}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding MachineName}"
                                                       Style="{StaticResource Body}" FontWeight="SemiBold"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="IP:" Style="{StaticResource Caption}"/>
                                            <TextBlock Grid.Column="1" Text="192.168.1.100"
                                                       Style="{StaticResource Body}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                        </Grid>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="PIN:" Style="{StaticResource Caption}"/>
                                            <TextBlock Grid.Column="1" Text="847293"
                                                       FontSize="20" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentPrimaryBrush}"
                                                       FontFamily="{StaticResource MonoFont}"/>
                                        </Grid>
                                    </StackPanel>

                                    <Button Content="🔄  Regenerate Code" Style="{StaticResource GhostButton}"
                                            HorizontalAlignment="Center" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- History View -->
                    <Grid x:Name="HistoryViewPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Transfer History" Style="{StaticResource H2}"/>
                            <TextBlock Text="Past transfers across all sessions"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,24"/>
                            <TextBlock Text="No transfer history yet."
                                       Style="{StaticResource BodySecondary}" Margin="0,40,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <!-- Settings View -->
                    <Grid x:Name="SettingsViewPanel" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="Settings" Style="{StaticResource H2}"/>
                            <TextBlock Text="Configure transfer and application preferences"
                                       Style="{StaticResource BodySecondary}" Margin="0,4,0,24"/>
                            
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Default Save Directory" Style="{StaticResource Body}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="~/Downloads/Shart" Style="{StaticResource Caption}"
                                               Margin="0,4,0,0" FontFamily="{StaticResource MonoFont}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Parallel Streams" Style="{StaticResource Body}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="4 TCP data streams (recommended: 4-8)"
                                               Style="{StaticResource Caption}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Auto-verify Checksum" Style="{StaticResource Body}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Enabled (xxHash64)" Style="{StaticResource Caption}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
